# Copy to ".env" and fill in only the provider you'll use. run.ps1 / run.sh load this automatically.
# Free, no credit card:
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
# Paid (optional):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Ollama needs NO key — install from https://ollama.com then:  ollama pull llama3.1

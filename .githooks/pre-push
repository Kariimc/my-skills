#!/bin/bash
set -uo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# Apex pre-push gate.
#   1. Warns (does NOT block) on a direct push to master — landing is allowed,
#      but never silent.
#   2. Runs the full apex gate suite; blocks the push on any HARD failure.
# Auto-armed by the SessionStart hook via core.hooksPath=.githooks.
# ─────────────────────────────────────────────────────────────────────────────

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
GATES="$ROOT/bin/apex-gates.sh"
[ -x "$GATES" ] || exit 0

# stdin: <local ref> <local sha> <remote ref> <remote sha>
# Read once — stdin can only be consumed a single time.
ZERO="0000000000000000000000000000000000000000"
REFS="$(cat)"
deletions=0
content=0

while read -r _localref localsha remoteref _remotesha; do
  [ -n "${remoteref:-}" ] || continue
  case "$remoteref" in
    refs/heads/master)
      echo "⚠ apex: pushing directly to ${remoteref#refs/heads/}. Allowed — but make sure this is intentional (the recommended flow is feature → review → land)." >&2
      ;;
  esac
  if [ "${localsha:-}" = "$ZERO" ]; then
    deletions=$((deletions+1))
  else
    content=$((content+1))
  fi
done <<< "$REFS"

# A branch deletion pushes no content: there is nothing for a gate to read. The
# suite (the doctor scan alone walks 420 skills, ~3.5 min) was running in full on
# every delete — pure latency, zero coverage. Skip ONLY when every ref in the
# push is a deletion; one real ref and the whole suite runs as before. This is
# not a bypass or a weakening: deleting a branch cannot introduce a defect into
# the trunk the gates protect.
if [ "$content" -eq 0 ] && [ "$deletions" -gt 0 ]; then
  echo "apex: deletion-only push ($deletions ref) — no content to gate, suite skipped." >&2
  exit 0
fi

if ! "$GATES" all; then
  echo "" >&2
  echo "✗ apex pre-push blocked: gate suite has HARD failures (above)." >&2
  echo "  Fix them, or run: bin/apex.sh" >&2
  exit 1
fi
